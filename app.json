{
  "expo": {
    "name": "Aspen Core",
    "slug": "aspen-m",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aspencore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aspencore.app",
      "infoPlist": {
        "NFCReaderUsageDescription": "Usado para autenticação segura via NFC",
        "NSFaceIDUsageDescription": "Usado para confirmar sua identidade antes de liberar o acesso"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.aspencore.app",
      "permissions": [
        "android.permission.NFC",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-local-authentication",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Usado para autenticação segura sem senha"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
    }
  ]
],
    "experiments": {
      "typedRoutes": true
    }
  }
}